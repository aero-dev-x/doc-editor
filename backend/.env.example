# PostgreSQL — async driver used by the app at runtime
DATABASE_URL=postgresql+asyncpg://docuser:docpass@localhost:5432/doceditor

# PostgreSQL — sync driver used only by Alembic migrations
SYNC_DATABASE_URL=postgresql+psycopg2://docuser:docpass@localhost:5432/doceditor

# JWT — generate a strong secret for production:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

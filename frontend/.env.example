# Docker Compose / nginx — used to proxy /api and /ws at the nginx layer
# Set to the backend container name when using Docker Compose
BACKEND_URL=http://localhost:8000

# Vercel / direct deployments — browser calls the backend directly
# Set this to your deployed backend URL (no trailing slash)
# Leave empty when running via Docker Compose (nginx proxying handles it)
VITE_API_URL=
